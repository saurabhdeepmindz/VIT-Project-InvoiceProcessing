# ═══════════════════════════════════════════════════════════════════════
# Invoice Processing Platform — Sample Environment Configuration (v3.1)
# Copy this file to .env and fill in the values.
# NEVER commit secrets or API keys to source control.
# ═══════════════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────────
NODE_ENV=development                        # development | staging | production
APP_PORT=3001
API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL 18) ─────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=invoice_processing
DATABASE_USER=invoice_user
DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_SYNCHRONIZE=false                  # NEVER true in production — use migrations
DATABASE_LOGGING=false

# ─── JWT Authentication ───────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_64_CHARS_HERE_DO_NOT_USE_DEFAULT
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_64_CHARS_HERE_DO_NOT_USE_DEFAULT
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Seeded admin for demo (EPIC-001 minimal)
# IMPORTANT: quote any value containing '#' — dotenv treats unquoted # as inline comment.
SEED_ADMIN_EMAIL=admin@invoice-platform.local
SEED_ADMIN_PASSWORD="ChangeMe!Admin#2026"
SEED_OPERATOR_EMAIL=operator@invoice-platform.local
SEED_OPERATOR_PASSWORD="ChangeMe!Op#2026"

# ─── File Storage ─────────────────────────────────────────────────────
# Choose: local | s3 | minio  (demo default: local Windows filesystem)
STORAGE_PROVIDER=local

# Local filesystem (used when STORAGE_PROVIDER=local)
# Use a Windows-friendly absolute path. Forward slashes work in Node.
LOCAL_STORAGE_PATH=D:/invoice-processing-data/storage

# AWS S3 (used when STORAGE_PROVIDER=s3)
AWS_S3_BUCKET=invoice-processing-files
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY

# MinIO (used when STORAGE_PROVIDER=minio — S3-compatible local)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET=invoice-processing

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# Storage subdirectories (relative to LOCAL_STORAGE_PATH or S3 prefixes)
UPLOAD_DIR_PATH=upload/
PROCESSED_DIR_PATH=processed/
OUTPUT_DIR_PATH=output/
REPORT_DIR_PATH=reports/

# ─── Image Download (v3.1 — fetches invoice images from CSV URLs) ────
IMG_MAX_DOWNLOAD_MB=30
IMG_DOWNLOAD_TIMEOUT_MS=180000
IMG_DOWNLOAD_RETRY=3
IMG_DOWNLOAD_BACKOFF_MS=1000                # initial backoff; doubles each attempt
# Comma-separated allowlist. Use '*' to disable the check (demo only).
IMG_URL_HOST_ALLOWLIST=api.cuup0dd28g-bridgesto1-p1-public.model-t.cc.commerce.ondemand.com

# ─── Extraction Mode (v3.1) ───────────────────────────────────────────
EXTRACTION_MODE=vision_first                # vision_first | ocr_first

# ─── Dead-Letter Queue (v3.1) ─────────────────────────────────────────
DLQ_ENABLED=true
DLQ_RETRY_AFTER_MINUTES=60

# ─── Observability (v3.1 — basic) ─────────────────────────────────────
HEALTHCHECK_ENABLED=true
METRICS_ENABLED=true
SWAGGER_ENABLED=true                        # /api/docs — dev only

# ─── Python AI Microservice ───────────────────────────────────────────
PYTHON_AI_SERVICE_URL=http://localhost:8001
PYTHON_AI_SERVICE_TIMEOUT_MS=60000          # generous for vision LLM
PYTHON_AI_RETRY_ATTEMPTS=3

# ─── LLM Provider (★ MODULAR — swap without any code changes) ─────────
# Set LLM_PROVIDER to the desired provider key. Only the corresponding
# API key section needs to be filled in.
#
# Available providers:
#   nano_banana   — Nano Banana AI (default)
#   openai        — OpenAI GPT-4o/GPT-4o-mini
#   anthropic     — Anthropic Claude
#   azure_openai  — Azure OpenAI Service

LLM_PROVIDER=nano_banana

# v3.1: Stub provider toggle (overrides LLM_PROVIDER when true).
# When true   → StubProvider returns deterministic canned JSON (no API calls, no keys needed)
# When false  → LLM_PROVIDER above is honoured; corresponding API key must be set
USE_STUB_PROVIDER=true

# ── Nano Banana (default real provider) ───────────────────────────────
NB_API_KEY=nb_CHANGE_ME_YOUR_NANO_BANANA_API_KEY
NB_API_BASE=https://api.nanobanana.ai/v1
NB_MODEL=nano-banana-large             # nano-banana-small | nano-banana-large
NB_MAX_TOKENS=2048
NB_TEMPERATURE=0.0                     # 0.0 = deterministic extraction (recommended)

# ── OpenAI (activate: LLM_PROVIDER=openai) ────────────────────────────
OPENAI_API_KEY=sk-CHANGE_ME_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o                    # gpt-4o | gpt-4o-mini (vision-capable)
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.0

# ── Anthropic (activate: LLM_PROVIDER=anthropic) ─────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-6      # vision-capable
ANTHROPIC_MAX_TOKENS=2048

# ── Azure OpenAI (activate: LLM_PROVIDER=azure_openai) ───────────────
AZURE_OPENAI_API_KEY=CHANGE_ME_AZURE_OPENAI_KEY
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-deployment
AZURE_OPENAI_API_VERSION=2024-10-21

# ─── OCR Engine (corroboration signal when EXTRACTION_MODE=vision_first) ──
# Choose: tesseract | azure_cv | none
OCR_PROVIDER=tesseract
OCR_MIN_CONFIDENCE=0.5
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
AZURE_CV_KEY=CHANGE_ME_AZURE_CV_KEY
AZURE_CV_ENDPOINT=https://YOUR_REGION.api.cognitive.microsoft.com

# ─── Batch Processing Scheduler ──────────────────────────────────────
BATCH_CRON_SCHEDULE=*/15 * * * *          # every 15 minutes
BATCH_MAX_CONCURRENT=5                    # max parallel batch jobs
BATCH_RETRY_ATTEMPTS=3
BATCH_RETRY_DELAY_MS=2000

# ─── Email / Notifications (optional) ─────────────────────────────────
EMAIL_PROVIDER=smtp                       # smtp | ses | disabled
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM=Invoice Processing <noreply@example.com>

# ─── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info                            # debug | info | warn | error
LOG_FORMAT=pretty                         # json | pretty
LOG_FILE_PATH=                            # empty = stdout only
AUDIT_LOG_PATH=                           # empty = stdout only

# ─── Security ────────────────────────────────────────────────────────
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
BCRYPT_SALT_ROUNDS=12

# ─── Python AI Service (settings for the FastAPI microservice) ───────
PYTHON_APP_PORT=8001
PYTHON_LOG_LEVEL=info
PYTHON_LOG_FORMAT=pretty
# MUST be JSON-array form (pydantic-settings parses List[str] fields as JSON).
PYTHON_ALLOWED_ORIGINS=["http://localhost:3001","http://localhost:3000"]
PYTHON_ENABLE_DOCS=true                   # set false in production

# ─── Frontend (Next.js public env vars) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=50
NEXT_PUBLIC_CONFIDENCE_WARN_THRESHOLD=70   # amber below this
NEXT_PUBLIC_CONFIDENCE_ERROR_THRESHOLD=30  # red below this
